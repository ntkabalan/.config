#!/usr/bin/env zsh

if [[ $# -eq 1 ]]; then
    selected=$1
else
    DIRS="$(echo ~/.config && find ~/Developer/github ~/Developer/sandbox -mindepth 1 -maxdepth 1 -type d)"
    selected=$(echo $DIRS | fzf --color=bg+:#2c2e33,gutter:-1)
fi

if [[ -z $selected ]]; then
    exit 0
fi

selected_name=$(basename "$selected" | tr -d '.')

# create the session (detached) if it doesn't already exist. this also starts
# the tmux server if nothing is running yet.
if ! tmux has-session -t=$selected_name 2> /dev/null; then
    tmux new-session -ds $selected_name -c $selected
fi

# attach when we're outside tmux; switch-client only works from within a client.
if [[ -z $TMUX ]]; then
    tmux attach-session -t $selected_name
else
    tmux switch-client -t $selected_name
fi
